<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sedgegration</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Sedgegration</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Workflows" asp-action="Index">Workflows</a>
                <a class="nav-link" asp-controller="Protocols" asp-action="Index">Protocols</a>
                <a class="nav-link" asp-controller="Requests" asp-action="Index">Requests</a>
                <a class="nav-link" asp-controller="Steps" asp-action="Index">Steps</a>
            </div>
            <div class="ms-auto d-flex align-items-center">
                <span class="text-light me-2">Service:</span>
                @await Component.InvokeAsync("ServiceStatus")
            </div>
        </div>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
